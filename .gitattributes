# Auto detect text files and perform LF normalization
* text=auto

# Source files
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Binary assets
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.ico binary
*.webp binary
*.avif binary

# Minified files — treat as generated
*.min.css linguist-generated
*.min.js linguist-generated
